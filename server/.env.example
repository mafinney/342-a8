# server/.env.example
# Copy this file to  server/.env  and fill in your real values.
# .env is gitignored — never commit your real credentials.

# Port the Express server listens on. 3000 matches the Vite proxy in vite.config.js.
PORT=3000

# MongoDB Atlas connection string (Atlas → Connect → Drivers → Node.js).
# Replace USER + PASS with your DB-user credentials, and put the DB name
# (platescout) right before the ? so Mongoose writes to that database.
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/platescout?retryWrites=true

# JWT signing secret. Long random string only you know.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Different from your DB password, different from your Atlas login.
JWT_SECRET=replace-with-a-long-random-string
